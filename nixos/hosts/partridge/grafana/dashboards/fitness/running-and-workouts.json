          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  w.started_at AS time,\n  SUM(es.weight_kg * es.reps) AS \"Total volume (kg)\"\nFROM workouts w\nJOIN workout_exercises we ON we.workout_id = w.id\nJOIN exercise_sets es ON es.workout_exercise_id = we.id\nWHERE w.deleted_at IS NULL\n  AND es.weight_kg IS NOT NULL\n  AND es.reps IS NOT NULL\n  AND $__timeFilter(w.started_at)\nGROUP BY w.started_at\nORDER BY w.started_at",
          "refId": "A"
        }
      ],
      "title": "Workout Sessions — Total Volume",
      "type": "timeseries"
