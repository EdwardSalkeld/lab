      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "exercise-tracker-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  w.started_at AS time,\n  we.base_name AS metric,\n  SUM(es.weight_kg * es.reps) AS volume\nFROM workouts w\nJOIN workout_exercises we ON we.workout_id = w.id\nJOIN exercise_sets es ON es.workout_exercise_id = we.id\nWHERE w.deleted_at IS NULL\n  AND es.weight_kg IS NOT NULL\n  AND es.reps IS NOT NULL\n  AND we.base_name IN (${exercise:singlequote})\n  AND $__timeFilter(w.started_at)\nGROUP BY w.started_at, we.base_name\nORDER BY w.started_at",
          "refId": "A"
        }
      ],
      "title": "$exercise",
      "type": "timeseries"
