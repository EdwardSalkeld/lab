          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH base AS (\n  SELECT\n    interval_start,\n    consumption\n  FROM usages\n  WHERE $__timeFilter(interval_start)\n    AND usage_type = 'electricity'\n),\nwith_cumulative AS (\n  SELECT\n    interval_start,\n    SUM(consumption) OVER (\n      ORDER BY interval_start\n      ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW\n    ) AS cumulative_consumption,\n    ROW_NUMBER() OVER (ORDER BY interval_start) AS rn,\n    COUNT(*) OVER () AS total_rows\n  FROM base\n)\nSELECT\n  interval_start AS time,\n  cumulative_consumption\nFROM with_cumulative\nWHERE ((rn - 1) % GREATEST(CEIL(total_rows / 80.0)::int, 1)) = 0\nORDER BY interval_start",
          "refId": "A",
