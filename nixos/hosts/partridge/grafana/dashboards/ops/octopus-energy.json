          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT interval_start AS time, consumption\nFROM usages\nWHERE $__timeFilter(interval_start)\n  AND usage_type = 'electricity'\nORDER BY interval_start",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 1000
          }
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "scheduler-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT interval_start AS time, consumption AS average_consumption\nFROM (\n  SELECT\n    interval_start,\n    consumption,\n    ROW_NUMBER() OVER (ORDER BY interval_start) AS rn,\n    COUNT(*) OVER () AS total_rows\n  FROM usages\n  WHERE $__timeFilter(interval_start)\n    AND usage_type = 'electricity'\n) t\nWHERE ((rn - 1) % GREATEST(CEIL(total_rows / 80.0)::int, 1)) = 0\nORDER BY interval_start",
          "refId": "B",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 1000
          }
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "scheduler-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT\n  DATE_BIN('1 hour'::interval, interval_start, '1970-01-01'::timestamptz) AS time,\n  AVG(consumption) AS avg_stat,\n  MIN(consumption) AS min_stat,\n  MAX(consumption) AS max_stat\nFROM usages\nWHERE $__timeFilter(interval_start)\n  AND usage_type = 'electricity'\nGROUP BY 1\nORDER BY 1",
          "refId": "C",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 1000
          }
        }
      ],
