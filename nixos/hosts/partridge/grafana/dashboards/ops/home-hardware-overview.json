          "datasource": {
            "type": "prometheus",
            "uid": "fdp9rmnopl3wgf"
          },
          "editorMode": "code",
          "expr": "sum by (host) (label_replace(node_load1{job=\"node\"}, \"host\", \"$1\", \"instance\", \"([^.:]+).*\"))",
          "instant": true,
          "range": false,
          "refId": "D",
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "fdp9rmnopl3wgf"
          },
          "editorMode": "code",
          "expr": "sum by (host) (label_replace((1 - node_filesystem_avail_bytes{job=\"node\",mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"node\",mountpoint=\"/\"}) * 100, \"host\", \"$1\", \"instance\", \"([^.:]+).*\"))",
          "instant": true,
          "range": false,
          "refId": "E",
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "fdp9rmnopl3wgf"
          },
          "editorMode": "code",
