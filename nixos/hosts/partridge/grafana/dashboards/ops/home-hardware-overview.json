          "editorMode": "code",
          "expr": "sum by (host) (label_replace(100 - (avg by (instance) (rate(node_cpu_seconds_total{job=\"node\",mode=\"idle\"}[5m])) * 100), \"host\", \"$1\", \"instance\", \"([^.:]+).*\"))",
