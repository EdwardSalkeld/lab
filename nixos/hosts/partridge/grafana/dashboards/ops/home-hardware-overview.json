          "datasource": {
            "type": "prometheus",
            "uid": "fdp9rmnopl3wgf"
          },
          "editorMode": "code",
          "expr": "sum by (host) (label_replace((1 - node_memory_MemAvailable_bytes{job=\"node\"} / node_memory_MemTotal_bytes{job=\"node\"}) * 100, \"host\", \"$1\", \"instance\", \"([^.:]+).*\"))",
          "instant": true,
          "range": false,
          "refId": "C",
          "format": "table"
