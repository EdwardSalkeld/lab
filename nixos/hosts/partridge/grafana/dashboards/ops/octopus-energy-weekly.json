      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "scheduler-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "WITH daily AS (\n  SELECT\n    DATE_TRUNC('day', interval_start AT TIME ZONE 'Europe/London') AS day_local,\n    SUM(consumption) AS day_kwh,\n    COUNT(*) AS reading_count\n  FROM usages\n  WHERE $__timeFilter(interval_start)\n    AND usage_type = 'electricity'\n  GROUP BY 1\n), complete_days AS (\n  SELECT day_local, day_kwh\n  FROM daily\n  WHERE reading_count >= 46\n), weekly AS (\n  SELECT\n    DATE_TRUNC('week', day_local) AT TIME ZONE 'Europe/London' AS time,\n    SUM(day_kwh) AS weekly_kwh,\n    COUNT(*) AS complete_day_count\n  FROM complete_days\n  GROUP BY 1\n), full_weeks AS (\n  SELECT time, weekly_kwh\n  FROM weekly\n  WHERE complete_day_count = 7\n)\nSELECT\n  time,\n  weekly_kwh,\n  AVG(weekly_kwh) OVER (\n    ORDER BY time\n    ROWS BETWEEN 3 PRECEDING AND CURRENT ROW\n  ) AS rolling_4w_avg_kwh\nFROM full_weeks\nORDER BY time",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 1000
          }
        }
      ],
      "title": "Weekly Electricity Usage",
      "type": "timeseries"
    },
